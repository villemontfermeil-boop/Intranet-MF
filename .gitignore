# Certificates and keys - ignore contents but keep directories
# (do NOT commit private keys or certs)
certs/*
IntranetFront/my-montfermeil/certs/*
Intranet/certs/*
# If you need to keep an empty certs folder, add a .gitkeep inside it
!certs/.gitkeep
!IntranetFront/my-montfermeil/certs/.gitkeep
!Intranet/certs/.gitkeep
*.pem
*.key
*.p12
*.jks
*.keystore
montfermeil-intranet+2.pem
montfermeil-intranet+2-key.pem

